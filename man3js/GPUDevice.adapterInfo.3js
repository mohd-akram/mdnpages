.TH "GPUDEVICE.ADAPTERINFO" "3JS" "July 28, 2025" "JavaScript" "JavaScript Reference Manual"
.SH NAME
GPUDevice.adapterInfo \- GPUDevice: adapterInfo property
.SH SYNOPSIS
\f[B]Secure context:\f[R] This feature is available only in secure
contexts (HTTPS).
.PP
\f[B]Note:\f[R] This feature is available in Web Workers.
.PP
The \f[B]\f[CB]adapterInfo\f[B]\f[R] read\-only property of the
\f[CR]GPUDevice\f[R] interface returns a \f[CR]GPUAdapterInfo\f[R]
object containing identifying information about the device\(cqs
originating adapter.
.SH VALUE
A \f[CR]GPUAdapterInfo\f[R] object instance.
.SH EXAMPLES
.SS Basic adapterInfo usage
.IP
.EX
\f[B]const\f[R] adapter = \f[B]await\f[R] navigator.gpu.requestAdapter();
\f[B]if\f[R] (!adapter) {
  \f[B]throw\f[R] Error(\(dqCouldn\(aqt request WebGPU adapter.\(dq);
}

\f[B]const\f[R] myDevice = \f[B]await\f[R] adapter.requestDevice();

\f[B]function\f[R] optimizeForGpuDevice(device) {
  \f[B]if\f[R] (device.adapterInfo.vendor === \(dqamd\(dq) {
    \f[I]// Use AMD\-specific optimizations\f[R]
  } \f[B]else\f[R] \f[B]if\f[R] (device.adapterInfo.architecture.includes(\(dqturing\(dq)) {
    \f[I]// Optimize for NVIDIA Turing architecture\f[R]
  }
}

optimizeForGpuDevice(myDevice);
.EE
