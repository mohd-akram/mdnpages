.TH "SPEECHRECOGNITION.ABORT" "3JS" "September 30, 2025" "JavaScript" "JavaScript Reference Manual"
.SH NAME
SpeechRecognition.abort \- SpeechRecognition: abort() method
.SH SYNOPSIS
The \f[B]\f[CB]abort()\f[B]\f[R] method of the Web Speech API stops the
speech recognition service from listening to incoming audio, and
doesn\(cqt attempt to return a \f[CR]SpeechRecognitionResult\f[R].
.SH SYNTAX
.IP
.EX
abort()
.EE
.SS Parameters
None.
.SS Return value
None (\f[CR]undefined\f[R]).
.SH EXAMPLES
.IP
.EX
\f[B]const\f[R] recognition = \f[B]new\f[R] SpeechRecognition();

\f[B]const\f[R] diagnostic = document.querySelector(\(dq.output\(dq);
\f[B]const\f[R] bg = document.querySelector(\(dqhtml\(dq);
\f[B]const\f[R] startBtn = document.querySelector(\(dq.start\(dq);
\f[B]const\f[R] abortBtn = document.querySelector(\(dq.abort\(dq);

startBtn.onclick = () \f[B]=>\f[R] {
  recognition.start();
  console.log(\(dqReady to receive a color command.\(dq);
};

abortBtn.onclick = () \f[B]=>\f[R] {
  recognition.abort();
  console.log(\(dqSpeech recognition aborted.\(dq);
};

recognition.onspeechend = () \f[B]=>\f[R] {
  recognition.stop();
  console.log(\(dqSpeech recognition has stopped.\(dq);
};
.EE
