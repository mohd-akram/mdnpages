  \f[B]background\-color\f[R]: red;
  \f[B]opacity\f[R]: 0.5;
  \f[B]display\f[R]: flex;
}

\&.carousel {
  \f[B]width\f[R]: 300px;
  \f[B]overflow\-x\f[R]: auto;
  \f[B]scroll\-snap\-type\f[R]: x mandatory;
  \f[B]display\f[R]: flex;
  \f[B]border\f[R]: solid;
  \f[I]/* outline: 200px solid rgba(0, 0, 0, 0.1); */\f[R]
}
\&.carousel img {
  \f[B]scroll\-snap\-stop\f[R]: always;
  \f[B]scroll\-snap\-align\f[R]: start;
