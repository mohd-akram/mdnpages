.TH "SET.HAS" "3JS" "September 22, 2025" "JavaScript" "JavaScript Reference Manual"
.SH NAME
Set.has \- Set.prototype.has()
.SH SYNOPSIS
The \f[B]\f[CB]has()\f[B]\f[R] method of \f[CR]Set\f[R] instances
returns a boolean indicating whether the specified value exists in this
\f[CR]Set\f[R] or not.
.IP
.EX
\f[B]const\f[R] \f[B]set\f[R] = \f[B]new\f[R] Set([1, 2, 3, 4, 5]);

console.log(\f[B]set\f[R].has(1));
\f[I]// Expected output: true\f[R]

console.log(\f[B]set\f[R].has(5));
\f[I]// Expected output: true\f[R]

console.log(\f[B]set\f[R].has(6));
\f[I]// Expected output: false\f[R]
.EE
.SH SYNTAX
.IP
.EX
has(value)
.EE
.SS Parameters
.TP
\f[B]value\f[R]
The value to test for presence in the \f[CR]Set\f[R] object.
.SS Return value
Returns \f[CR]true\f[R] if the specified value exists in the
\f[CR]Set\f[R] object; otherwise \f[CR]false\f[R].
.SH EXAMPLES
.SS Using has()
.IP
.EX
\f[B]const\f[R] mySet = \f[B]new\f[R] Set();
mySet.add(\(dqfoo\(dq);

console.log(mySet.has(\(dqfoo\(dq)); \f[I]// true\f[R]
console.log(mySet.has(\(dqbar\(dq)); \f[I]// false\f[R]

\f[B]const\f[R] \f[B]set\f[R] = \f[B]new\f[R] Set();
\f[B]const\f[R] obj = { key1: 1 };
\f[B]set\f[R].add(obj);

console.log(\f[B]set\f[R].has(obj)); \f[I]// true\f[R]
console.log(\f[B]set\f[R].has({ key1: 1 })); \f[I]// false, because they are different object references\f[R]
console.log(\f[B]set\f[R].add({ key1: 1 })); \f[I]// now set contains 2 entries\f[R]
.EE
